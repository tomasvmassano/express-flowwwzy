# ─────────── Studio (production pipeline) ───────────
# Vision API for design DNA extraction.
ANTHROPIC_API_KEY=sk-ant-...
# Screenshot service.
APIFY_API_TOKEN=apify_api_...
# Studio auth — set BOTH for the auth gate to work.
# STUDIO_PASSWORD: minimum 6 chars; users enter this at /studio/login.
# STUDIO_AUTH_SECRET: minimum 16 chars; HMAC key for signed session cookies.
#                     Treat like a password and rotate if leaked.
STUDIO_PASSWORD=
STUDIO_AUTH_SECRET=

# Optional legacy shared secret to lock /api/studio/* (now redundant with
# the auth gate; keep blank unless you want external CI/automation that
# can't carry cookies).
STUDIO_API_KEY=

# ─────────── LP — Stripe ───────────
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# VSL (Video Sales Letter) — full embed URL of your YouTube/Vimeo/Wistia video.
# YouTube: https://www.youtube.com/embed/<video-id>
# Vimeo:   https://player.vimeo.com/video/<video-id>
NEXT_PUBLIC_VSL_EMBED_URL=
# Optional thumbnail/poster shown before play. Drop file in public/images/.
NEXT_PUBLIC_VSL_POSTER_URL=/images/vsl-poster.jpg

# Analytics
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=

# Lead capture (Zapier / Make / CRM webhook)
LEAD_WEBHOOK_URL=

# Contact
NEXT_PUBLIC_WHATSAPP_NUMBER=351912345678
NEXT_PUBLIC_CONTACT_EMAIL=hello@flowwwzy.com
